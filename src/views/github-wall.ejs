                                                    <circle cx="12" cy="12" r="4"></circle>
                                                    <path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-4 8"></path>
                                                </svg>
                                                <%= username %>
                                            </span><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                stroke-linecap="round" stroke-linejoin="round"
                                                class="lucide lucide-dot size-5" aria-hidden="true">
                                                <circle cx="12.1" cy="12.1" r="1"></circle>
                                            </svg><span class="flex items-center gap-1 whitespace-nowrap"><svg
                                                    xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                    viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                    class="lucide lucide-user size-4" aria-hidden="true">
                                                    <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                                                    <circle cx="12" cy="7" r="4"></circle>
                                                </svg><span>
                                                    <%= followers %>
                                                </span><span class="opacity-70">followers</span></span><svg
                                                xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                stroke-linecap="round" stroke-linejoin="round"
                                                class="lucide lucide-dot size-5" aria-hidden="true">
                                                <circle cx="12.1" cy="12.1" r="1"></circle>
                                            </svg><span class="flex items-center gap-1 whitespace-nowrap"><span>
                                                    <%= following %>
                                                </span><span class="opacity-70">following</span></span></div>
                                    </div>
                                    <div class="ml-auto flex shrink-0 flex-col items-end gap-0.5 text-xs"><a
                                            class="pb-2" target="_blank" href="https://github.com/<%= username %>"><span
                                                class="inline-block size-9"><svg viewBox="0 0 24 24">
                                                    <path clip-rule="evenodd"
                                                        d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385c.6.105.825-.255.825-.57c0-.285-.015-1.23-.015-2.235c-3.015.555-3.795-.735-4.035-1.41c-.135-.345-.72-1.41-1.23-1.695c-.42-.225-1.02-.78-.015-.795c.945-.015 1.62.87 1.845 1.23c1.08 1.815 2.805 1.305 3.495.99c.105-.78.42-1.305.765-1.605c-2.67-.3-5.46-1.335-5.46-5.925c0-1.305.465-2.385 1.23-3.225c-.12-.3-.54-1.53.12-3.18c0 0 1.005-.315 3.3 1.23c.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23c.66 1.65.24 2.88.12 3.18c.765.84 1.23 1.905 1.23 3.225c0 4.605-2.805 5.625-5.475 5.925c.435.375.81 1.095.81 2.22c0 1.605-.015 2.895-.015 3.3c0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z"
                                                        fill="currentcolor" fill-rule="evenodd"></path>
                                                </svg></span></a><span class="opacity-70">
                                            <%= total %> Commits
                                        </span><span class="opacity-70">
                                            <% if (years===1) { %>
                                                In <%= contributions[0].year %>
                                                    <% } else { %>
                                                        <%= years %> Years
                                                            <% } %>
                                        </span></div>
                                </div>
                            </div>
                            <% contributions.forEach(yearData=> { %>
                                <div class="flex flex-col gap-y-6 p-6">
                                    <div class=" group">
                                        <div class="mb-2 flex items-center">
                                            <div class="text-sm tabular-nums"><span class="mr-2 font-medium">
                                                    <%= yearData.year %>:
                                                </span><span class="opacity-80">
                                                    <%= yearData.total %>
                                                        Contributions
                                                </span></div><button
                                                class="group/inspect ml-auto rounded bg-[var(--theme-secondary)] px-2 py-1 text-sm text-current opacity-0 outline outline-transparent transition-all hover:outline-[var(--theme-border)] group-hover:opacity-100"><a
                                                    class="inline-flex items-center gap-0.5" target="_blank"
                                                    href="/api/github/wall?username=<%= username %>&year=<%= yearData.year %><%= typeof zoom !== 'undefined' ? '&zoom=' + zoom : '' %><%= typeof isBeauty !== 'undefined' && isBeauty ? '&beauty=true' : '' %>"><span
                                                        class="opacity-70 transition group-hover/inspect:opacity-100">Inspect</span><svg
                                                        xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                        viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                        class="lucide lucide-chevron-right size-4 transition group-hover/inspect:translate-x-0.5"
                                                        aria-hidden="true">
                                                        <path d="m9 18 6-6-6-6"></path>
                                                    </svg></a></button>
                                        </div>
                                        <div class="Graph_graph__2ANUK">
                                            <ul class="Graph_months__7q6KF">
                                                <li>Jan</li>
                                                <li>Feb</li>
                                                <li>Mar</li>
                                                <li>Apr</li>
                                                <li>May</li>
                                                <li>Jun</li>
                                                <li>Jul</li>
                                                <li>Aug</li>
                                                <li>Sep</li>
                                                <li>Oct</li>
                                                <li>Nov</li>
                                                <li>Dec</li>
                                            </ul>
                                            <ul class="Graph_grids__ACxwI Graph_blocks__2du8I">
                                                <% /* 计算一年中的星期数（通常是52或53） */ const
                                                    weeksInYear=Math.ceil(yearData.contributions.flat().length / 7); /*
                                                    处理年初的空白格子（如果第一天不是星期日） */ const firstDayDate=new
                                                    Date(yearData.contributions[0][0].date); const
                                                    firstDayOfWeek=firstDayDate.getDay(); /* 0是星期日，1是星期一... */ /*
                                                    添加年初的空白格子 */ for (let i=0; i < firstDayOfWeek; i++) { %>
                                                    <li data-level="-1"></li>
                                                    <% } /* 添加所有贡献数据的格子 */ yearData.contributions.forEach(week=> {
                                                        week.forEach(day => { %>
                                                        <li data-level="<%= day.intensity %>"
                                                            data-date="<%= day.date %>" data-count="<%= day.count %>"
                                                            class="contribution-block"></li>
                                                        <% }); }); /* 计算年末需要添加的空白格子数 */ const
                                                            lastWeek=yearData.contributions[yearData.contributions.length
                                                            - 1]; const remainingDays=7 - lastWeek.length; /* 添加年末的空白格子
                                                            */ for (let i=0; i < remainingDays; i++) { %>
                                                            <li data-level="-1"></li>
                                                            <% } %>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                                    <div
                                        class="border-t-[1.5px] border-t-[color-mix(in_srgb,var(--theme-border)_50%,transparent)] px-6 py-3">
                                        <div class="flex items-center justify-end whitespace-nowrap text-xs opacity-40">
                                            <span>Generated by
                                            </span><a style="color: #49B1F5;" class="ml-1"
                                                href="https://yik.at">yiiko</a><span class="ml-1">
                                                Api
                                            </span>
                                        </div>
                                    </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="absolute inset-0"></div>
        </div>
    </div>

    <!-- 添加tooltip元素 -->
    <div id="tooltip" class="tooltip"></div>

    <!-- 添加JavaScript代码处理tooltip显示 -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const tooltip = document.getElementById('tooltip');
            const blocks = document.querySelectorAll('.contribution-block');

            // 格式化日期函数
            function formatDate(dateStr) {
                const date = new Date(dateStr);
                const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
                return date.toLocaleDateString('zh-CN', options);
            }

            // 更新tooltip位置的函数，考虑滚动位置
            function updateTooltipPosition(element) {
                const rect = element.getBoundingClientRect();
                const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                const scrollLeft = window.pageXOffset || document.documentElement.scrollLeft;

                tooltip.style.position = 'fixed'; // 使用fixed定位，相对于视口
                tooltip.style.left = (rect.left + rect.width / 2) + 'px';
                tooltip.style.top = (rect.top - 5) + 'px';
            }

            blocks.forEach(block => {
                if (block.dataset.level === '-1') return; // 跳过空白格子

                block.addEventListener('mouseover', function (e) {
                    const date = this.dataset.date;
                    const count = this.dataset.count;

                    // 将日期格式化为 yyyy-mm-dd
                    const dateObj = new Date(date);
                    const year = dateObj.getFullYear();
                    const month = String(dateObj.getMonth() + 1).padStart(2, '0');
                    const day = String(dateObj.getDate()).padStart(2, '0');
                    const formattedDate = `${year}-${month}-${day}`;

                    tooltip.textContent = `${count} contributions in ${formattedDate}`;
                    tooltip.style.opacity = '1';

                    // 更新tooltip位置
                    updateTooltipPosition(this);
                });

                block.addEventListener('mouseout', function () {
                    tooltip.style.opacity = '0';
                });
            });

            // 处理鼠标移动时tooltip跟随
            document.addEventListener('mousemove', function (e) {
                const hoveredBlock = e.target.closest('.contribution-block');
                if (hoveredBlock && hoveredBlock.dataset.level !== '-1') {
                    updateTooltipPosition(hoveredBlock);
                }
            });

            // 添加滚动事件监听器，在滚动时更新tooltip位置
            window.addEventListener('scroll', function () {
                const hoveredBlock = document.querySelector('.contribution-block:hover');
                if (hoveredBlock && hoveredBlock.dataset.level !== '-1') {
                    updateTooltipPosition(hoveredBlock);
                }
            });
        });
    </script>
</body>

</html>