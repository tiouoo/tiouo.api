                            </svg></div>
                    </div>
                    <div>
                        <div>
                            <div class="px-6 pt-2">
                                <div class="flex w-full items-center"><a class="mr-4 flex shrink-0 items-center"
                                        target="_blank" href="https://github.com/<%= username %>"><span
                                            class="flex size-20 items-center"><span
                                                class="size-full overflow-hidden rounded-full bg-[var(--level-0)] "><img
                                                    src="<%= avatarUrl %>" alt="<%= username %> 's avatar."
                                                    class="h-full w-full"></span></span></a>
                                    <div class="flex basis-1/2 flex-col gap-1">
                                        <div><span class="text-xl font-semibold" translate="no">
                                                <%= displayName %>
                                            </span></div>
                                        <div class="flex items-center gap-y-1 text-sm"><span class="flex items-center"
                                                translate="no"><svg xmlns="http://www.w3.org/2000/svg" width="24"
